# Azani storefront — Kenya/KES, hardcoded brand identity in src/.

# Backend URL (e.g. https://azani-api-production.up.railway.app for production)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Create in Medusa Admin: Settings → Publishable API Keys → Create, then copy the key
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=your_publishable_api_key_here

# Site URL used for OpenGraph metadataBase. Defaults to https://azani.shop.
# NEXT_PUBLIC_SITE_URL=https://azani.shop

# Google OAuth (leave empty to disable Google sign-in)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
