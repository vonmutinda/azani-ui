# Azani storefront — Kenya/KES, hardcoded brand identity in src/.

# Backend URL (e.g. https://azani-api-production.up.railway.app for production)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Create in Medusa Admin: Settings → Publishable API Keys → Create, then copy the key
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=your_publishable_api_key_here

# Site URL used for OpenGraph metadataBase. Defaults to https://azani.shop.
# NEXT_PUBLIC_SITE_URL=https://azani.shop

# Google OAuth (leave empty to disable Google sign-in)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Storefront contact details (used in footer and floating WhatsApp button).
# All fall back to placeholders if unset.
# NEXT_PUBLIC_AZANI_PHONE=+254700000000
# NEXT_PUBLIC_AZANI_PHONE_DISPLAY=+254 700 000 000
# NEXT_PUBLIC_AZANI_EMAIL=hello@azani.shop

# Social media URLs (footer "Follow us" row).
# NEXT_PUBLIC_AZANI_INSTAGRAM_URL=https://instagram.com/azani
# NEXT_PUBLIC_AZANI_FACEBOOK_URL=https://facebook.com/azani
# NEXT_PUBLIC_AZANI_TIKTOK_URL=https://tiktok.com/@azani

# WhatsApp number for the floating chat button. Digits only (wa.me strips '+' anyway).
# NEXT_PUBLIC_AZANI_WHATSAPP_NUMBER=254700000000
